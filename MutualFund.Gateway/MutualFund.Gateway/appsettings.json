{
  "JwtSettings": {
    "SecretKey": "AMFINAV-Super-Secret-Key-2026-Must-Be-32-Chars-Min!",
    "Issuer": "AMFINAV.AuthAPI",
    "Audience": "AMFINAV.Apps"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Ocelot": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/gateway-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
