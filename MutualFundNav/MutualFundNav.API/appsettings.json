{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=MutualFundDbV2;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "AppSettings": {
    "NavSourceUrl": "https://portal.amfiindia.com/spages/NAVAll.txt",
    "NseHolidayApiUrl": "https://www.nseindia.com/api/holiday-master?type=trading",
    "ScheduleTime": "08:30:00",
    "RetryCount": 3,
    "RetryDelaySeconds": 10
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topics": {
      "NavFileProcessed": "nav-file-processed",
      "MarketHoliday":    "market-holidays"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/mutualfundnav-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
